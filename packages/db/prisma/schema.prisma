generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceRole {
  owner
  admin
  product
  engineer
  reviewer
  billing
}

enum CoreLoopStatus {
  request_intake
  clarification
  prd_draft
  prd_approved
  tasks_generated
  development
  review_running
  fixes_needed
  ready_for_approval
  approved
  rejected
  shipped
}

enum FeatureRequestPriority {
  low
  medium
  high
  urgent
}

enum FeatureRequestSource {
  manual
  email_import
  support_ticket
  customer_call_transcript
}

enum ClarificationQuestionStatus {
  open
  answered
  skipped
}

enum PRDStatus {
  draft
  approved
  rejected
  superseded
}

enum EngineeringTaskStatus {
  todo
  in_progress
  blocked
  in_review
  done
  canceled
}

enum PullRequestStatus {
  draft
  open
  merged
  closed
}

enum AIReviewRunStatus {
  queued
  running
  completed
  failed
}

enum AIReviewIssueSeverity {
  info
  low
  medium
  high
  critical
}

enum AIReviewIssueStatus {
  open
  fixed
  dismissed
}

enum HumanApprovalDecision {
  approved
  rejected
  changes_requested
}

enum ReleaseStatus {
  planned
  in_progress
  shipped
  failed
  rolled_back
}

enum BillingSubscriptionStatus {
  trialing
  active
  past_due
  canceled
  unpaid
}

enum UsageLedgerEventType {
  credit
  debit
  adjustment
}

enum WebhookEventStatus {
  pending
  processed
  failed
  ignored
}

model User {
  id                 String               @id @default(cuid())
  email              String               @unique
  name               String?
  avatarUrl          String?
  image              String?
  emailVerified      Boolean              @default(false)
  sessions           Session[]
  accounts           Account[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  workspaceMembers   WorkspaceMember[]
  featureRequests    FeatureRequest[]     @relation("FeatureRequestRequester")
  clarificationAnswers ClarificationQuestion[] @relation("ClarificationAnswerer")
  humanApprovals     HumanApproval[]
}


model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Workspace {
  id                    String                @id @default(cuid())
  name                  String
  slug                  String                @unique
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  members               WorkspaceMember[]
  projects              Project[]
  repositories          Repository[]
  featureRequests       FeatureRequest[]
  clarificationQuestions ClarificationQuestion[]
  prds                  PRD[]
  engineeringTasks      EngineeringTask[]
  taskBoardColumns      TaskBoardColumn[]
  pullRequests          PullRequest[]
  pullRequestFiles      PullRequestFile[]
  aiReviewRuns          AIReviewRun[]
  aiReviewIssues        AIReviewIssue[]
  humanApprovals        HumanApproval[]
  releases              Release[]
  billingSubscriptions  BillingSubscription[]
  usageLedger           UsageLedger[]
  webhookEvents         WebhookEvent[]
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(engineer)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model Project {
  id              String           @id @default(cuid())
  workspaceId     String
  name            String
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  repositories    Repository[]
  featureRequests FeatureRequest[]
  taskBoardColumns TaskBoardColumn[]
  releases        Release[]

  @@index([workspaceId])
  @@unique([workspaceId, name])
}

model Repository {
  id             String        @id @default(cuid())
  workspaceId    String
  projectId      String?
  provider       String        @default("github")
  owner          String
  name           String
  defaultBranch  String        @default("main")
  externalId     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  workspace      Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project        Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  pullRequests   PullRequest[]
  webhookEvents  WebhookEvent[]

  @@index([workspaceId])
  @@index([projectId])
  @@unique([workspaceId, provider, owner, name])
}

model FeatureRequest {
  id                     String                  @id @default(cuid())
  workspaceId            String
  projectId              String?
  requesterId            String?
  title                  String
  description            String
  priority               FeatureRequestPriority  @default(medium)
  source                 FeatureRequestSource    @default(manual)
  status                 CoreLoopStatus          @default(request_intake)
  metadata               Json?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  workspace              Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project                Project?                @relation(fields: [projectId], references: [id], onDelete: SetNull)
  requester              User?                   @relation("FeatureRequestRequester", fields: [requesterId], references: [id], onDelete: SetNull)
  clarificationQuestions ClarificationQuestion[]
  prds                   PRD[]
  engineeringTasks       EngineeringTask[]
  pullRequests           PullRequest[]
  releases               Release[]

  @@index([workspaceId, status])
  @@index([projectId])
  @@index([requesterId])
}

model ClarificationQuestion {
  id               String                       @id @default(cuid())
  workspaceId      String
  featureRequestId String
  question         String
  answer           String?
  status           ClarificationQuestionStatus  @default(open)
  answeredById     String?
  answeredAt       DateTime?
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt
  workspace        Workspace                    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  featureRequest   FeatureRequest              @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)
  answeredBy       User?                        @relation("ClarificationAnswerer", fields: [answeredById], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
  @@index([featureRequestId])
}

model PRD {
  id               String          @id @default(cuid())
  workspaceId      String
  featureRequestId String
  title            String
  content          String
  status           PRDStatus       @default(draft)
  version          Int             @default(1)
  approvedAt       DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  workspace        Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  featureRequest   FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)
  engineeringTasks EngineeringTask[]

  @@index([workspaceId, status])
  @@index([featureRequestId])
  @@unique([featureRequestId, version])
}

model EngineeringTask {
  id               String                @id @default(cuid())
  workspaceId      String
  featureRequestId String
  prdId            String?
  columnId         String?
  title            String
  description      String?
  status           EngineeringTaskStatus @default(todo)
  position         Int                   @default(0)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  workspace        Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  featureRequest   FeatureRequest        @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)
  prd              PRD?                  @relation(fields: [prdId], references: [id], onDelete: SetNull)
  column           TaskBoardColumn?      @relation(fields: [columnId], references: [id], onDelete: SetNull)
  pullRequests     PullRequest[]

  @@index([workspaceId, status])
  @@index([featureRequestId])
  @@index([prdId])
  @@index([columnId])
}

model TaskBoardColumn {
  id          String            @id @default(cuid())
  workspaceId String
  projectId   String?
  name        String
  position    Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project?          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks       EngineeringTask[]

  @@index([workspaceId])
  @@index([projectId])
  @@unique([workspaceId, projectId, name])
}

model PullRequest {
  id               String            @id @default(cuid())
  workspaceId      String
  repositoryId     String
  featureRequestId String?
  engineeringTaskId String?
  externalId       String?
  number           Int
  title            String
  url              String
  branchName       String
  status           PullRequestStatus @default(open)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  repository       Repository        @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  featureRequest   FeatureRequest?   @relation(fields: [featureRequestId], references: [id], onDelete: SetNull)
  engineeringTask  EngineeringTask?  @relation(fields: [engineeringTaskId], references: [id], onDelete: SetNull)
  files            PullRequestFile[]
  aiReviewRuns     AIReviewRun[]
  humanApprovals   HumanApproval[]
  releases         Release[]

  @@index([workspaceId, status])
  @@index([repositoryId])
  @@index([featureRequestId])
  @@index([engineeringTaskId])
  @@unique([repositoryId, number])
}

model PullRequestFile {
  id            String      @id @default(cuid())
  workspaceId   String
  pullRequestId String
  path          String
  status        String?
  additions     Int         @default(0)
  deletions     Int         @default(0)
  patch         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  workspace     Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pullRequest   PullRequest @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
  aiReviewIssues AIReviewIssue[]

  @@index([workspaceId])
  @@index([pullRequestId])
  @@unique([pullRequestId, path])
}

model AIReviewRun {
  id            String            @id @default(cuid())
  workspaceId   String
  pullRequestId String
  status        AIReviewRunStatus @default(queued)
  model         String
  summary       String?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  workspace     Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pullRequest   PullRequest       @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
  issues        AIReviewIssue[]

  @@index([workspaceId, status])
  @@index([pullRequestId])
}

model AIReviewIssue {
  id                String                 @id @default(cuid())
  workspaceId       String
  aiReviewRunId     String
  pullRequestFileId String?
  title             String
  description       String
  severity          AIReviewIssueSeverity  @default(medium)
  status            AIReviewIssueStatus    @default(open)
  line              Int?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  workspace         Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  aiReviewRun       AIReviewRun            @relation(fields: [aiReviewRunId], references: [id], onDelete: Cascade)
  pullRequestFile   PullRequestFile?       @relation(fields: [pullRequestFileId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
  @@index([aiReviewRunId])
  @@index([pullRequestFileId])
}

model HumanApproval {
  id            String                @id @default(cuid())
  workspaceId   String
  pullRequestId String
  approverId    String?
  decision      HumanApprovalDecision
  comment       String?
  decidedAt     DateTime              @default(now())
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  workspace     Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pullRequest   PullRequest           @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
  approver      User?                 @relation(fields: [approverId], references: [id], onDelete: SetNull)

  @@index([workspaceId, decision])
  @@index([pullRequestId])
  @@index([approverId])
}

model Release {
  id               String          @id @default(cuid())
  workspaceId      String
  projectId        String?
  featureRequestId String?
  pullRequestId    String?
  version          String?
  title            String
  notes            String?
  status           ReleaseStatus   @default(planned)
  shippedAt        DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  workspace        Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project          Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  featureRequest   FeatureRequest? @relation(fields: [featureRequestId], references: [id], onDelete: SetNull)
  pullRequest      PullRequest?    @relation(fields: [pullRequestId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
  @@index([projectId])
  @@index([featureRequestId])
  @@index([pullRequestId])
}

model BillingSubscription {
  id                 String                    @id @default(cuid())
  workspaceId        String
  provider           String                    @default("stripe")
  providerCustomerId String?
  providerSubscriptionId String?               @unique
  plan               String
  status             BillingSubscriptionStatus @default(trialing)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  workspace          Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
}

model UsageLedger {
  id          String               @id @default(cuid())
  workspaceId String
  eventType   UsageLedgerEventType
  units       Int
  description String?
  metadata    Json?
  occurredAt  DateTime             @default(now())
  createdAt   DateTime             @default(now())
  workspace   Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, occurredAt])
}

model WebhookEvent {
  id           String             @id @default(cuid())
  workspaceId  String
  repositoryId String?
  provider     String             @default("github")
  eventType    String
  deliveryId   String
  payload      Json
  status       WebhookEventStatus  @default(pending)
  processedAt  DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  workspace    Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  repository   Repository?        @relation(fields: [repositoryId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
  @@index([repositoryId])
  @@unique([provider, deliveryId])
}
